          "expr": "minio_cluster_capacity_usable_total_bytes{job=\"minio\"}",
          "legendFormat": "Usable Total",
          "refId": "A"
        },
        {
          "expr": "minio_cluster_capacity_usable_total_bytes{job=\"minio\"} - minio_cluster_capacity_usable_free_bytes{job=\"minio\"}",
