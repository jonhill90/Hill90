        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "textMode": "auto"
      },
      "targets": [
        {
          "expr": "minio_node_process_uptime_seconds{job=\"minio\"}",
          "legendFormat": "Uptime",
          "refId": "A"
        }
