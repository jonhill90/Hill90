      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(http_server_requests_seconds_count{job=\"keycloak\"}[5m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
