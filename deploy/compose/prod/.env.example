# Hill90 Production Environment Variables
# Copy this to .env and fill in actual values
# OR decrypt from infra/secrets/prod.enc.env

# Version
VERSION=latest

# Database
DB_USER=hill90
DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
DB_NAME=hill90

# JWT
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET
JWT_PRIVATE_KEY=REPLACE_WITH_RSA_PRIVATE_KEY
JWT_PUBLIC_KEY=REPLACE_WITH_RSA_PUBLIC_KEY

# API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE
OPENAI_API_KEY=sk-REPLACE

# Traefik/ACME
ACME_EMAIL=admin@hill90.com
TRAEFIK_ADMIN_PASSWORD_HASH=REPLACE_WITH_HTPASSWD_HASH

# Keycloak
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD

# Auth.js / Keycloak integration
AUTH_SECRET=REPLACE_WITH_RANDOM_SECRET
AUTH_KEYCLOAK_ID=hill90-ui
AUTH_KEYCLOAK_SECRET=REPLACE_WITH_KEYCLOAK_CLIENT_SECRET
AUTH_KEYCLOAK_ISSUER=https://auth.hill90.com/realms/hill90
AUTH_URL=https://hill90.com

# MinIO Object Storage
MINIO_ROOT_USER=REPLACE_WITH_MINIO_USER
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_PASSWORD

# Observability
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
