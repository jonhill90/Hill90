# Hill90 AgentBox Browser Profile
# Extends standard agentbox with Playwright + Chromium for web automation.
# Build after standard: docker build -f Dockerfile.browser -t hill90/agentbox-browser:latest .

FROM hill90/agentbox:latest

USER root

# Install Playwright system dependencies (Chromium)
RUN apt-get update && apt-get install -y --no-install-recommends \
    libnss3 \
    libnspr4 \
    libdbus-1-3 \
    libatk1.0-0 \
    libatk-bridge2.0-0 \
    libcups2 \
    libdrm2 \
    libxkbcommon0 \
    libxcomposite1 \
    libxdamage1 \
    libxfixes3 \
    libxrandr2 \
    libgbm1 \
    libpango-1.0-0 \
    libcairo2 \
    libasound2 \
    libatspi2.0-0 \
    fonts-liberation \
    && rm -rf /var/lib/apt/lists/*

# Install Playwright Python package + Chromium browser
RUN pip install --no-cache-dir playwright==1.49.1 && \
    PLAYWRIGHT_BROWSERS_PATH=/data/browsers playwright install chromium

# Ensure browser cache is owned by agentuser
RUN chown -R agentuser:agentuser /data/browsers

USER agentuser

ENV PLAYWRIGHT_BROWSERS_PATH=/data/browsers
