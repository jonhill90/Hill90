    "@opentelemetry/semantic-conventions": "^1.39.0",
    "@types/ws": "^8.18.1",
    "axios": "^1.13.5",
    "cors": "^2.8.5",
    "dockerode": "^4.0.9",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
