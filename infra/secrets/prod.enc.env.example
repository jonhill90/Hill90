# Example Production Secrets
# Copy this to prod.env, fill in values, then encrypt with:
# sops -e prod.env > prod.enc.env && rm prod.env

# VPS Configuration
VPS_HOST=hill90-vps
VPS_IP=REPLACE_WITH_VPS_IP
TAILSCALE_AUTH_KEY=tskey-auth-REPLACE

# Database
DB_USER=hill90
DB_PASSWORD=REPLACE_WITH_SECURE_PASSWORD
DB_NAME=hill90

# JWT Secrets
JWT_SECRET=REPLACE_WITH_RANDOM_SECRET
JWT_PUBLIC_KEY=REPLACE_WITH_RSA_PUBLIC_KEY
JWT_PRIVATE_KEY=REPLACE_WITH_RSA_PRIVATE_KEY

# Service Secrets
INTERNAL_SERVICE_SECRET=REPLACE_WITH_RANDOM_SECRET

# API Keys
ANTHROPIC_API_KEY=sk-ant-REPLACE
OPENAI_API_KEY=sk-REPLACE

# Keycloak Admin
KC_ADMIN_USERNAME=admin
KC_ADMIN_PASSWORD=REPLACE_WITH_ADMIN_PASSWORD

# MinIO Object Storage
MINIO_ROOT_USER=REPLACE_WITH_MINIO_USER
MINIO_ROOT_PASSWORD=REPLACE_WITH_MINIO_PASSWORD

# UI Auth (NextAuth)
AUTH_KEYCLOAK_ID=REPLACE_WITH_KEYCLOAK_CLIENT_ID
AUTH_KEYCLOAK_SECRET=REPLACE_WITH_KEYCLOAK_CLIENT_SECRET
AUTH_SECRET=REPLACE_WITH_NEXTAUTH_SECRET

# Email (ACME)
ACME_EMAIL=admin@hill90.com
ACME_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory

# Traefik Dashboard
TRAEFIK_ADMIN_PASSWORD_HASH=REPLACE_WITH_HTPASSWD_HASH

# DNS Manager
HOSTINGER_API_KEY=REPLACE_WITH_HOSTINGER_API_KEY

# SMTP (Hostinger)
SMTP_PASSWORD=REPLACE_WITH_SMTP_PASSWORD

# Observability
GRAFANA_ADMIN_PASSWORD=REPLACE_WITH_GRAFANA_PASSWORD

# GitHub Container Registry
GHCR_TOKEN=ghp_REPLACE

# OpenBao (Vault) — unseal key + per-service AppRole credentials
OPENBAO_UNSEAL_KEY=REPLACE_WITH_UNSEAL_KEY
VAULT_DB_ROLE_ID=REPLACE_WITH_ROLE_ID
VAULT_DB_SECRET_ID=REPLACE_WITH_SECRET_ID
VAULT_API_ROLE_ID=REPLACE_WITH_ROLE_ID
VAULT_API_SECRET_ID=REPLACE_WITH_SECRET_ID
VAULT_AI_ROLE_ID=REPLACE_WITH_ROLE_ID
VAULT_AI_SECRET_ID=REPLACE_WITH_SECRET_ID
VAULT_AUTH_ROLE_ID=REPLACE_WITH_ROLE_ID
VAULT_AUTH_SECRET_ID=REPLACE_WITH_SECRET_ID
VAULT_UI_ROLE_ID=REPLACE_WITH_ROLE_ID
VAULT_UI_SECRET_ID=REPLACE_WITH_SECRET_ID
VAULT_MINIO_ROLE_ID=REPLACE_WITH_ROLE_ID
VAULT_MINIO_SECRET_ID=REPLACE_WITH_SECRET_ID
VAULT_INFRA_ROLE_ID=REPLACE_WITH_ROLE_ID
VAULT_INFRA_SECRET_ID=REPLACE_WITH_SECRET_ID
VAULT_OBSERVABILITY_ROLE_ID=REPLACE_WITH_ROLE_ID
VAULT_OBSERVABILITY_SECRET_ID=REPLACE_WITH_SECRET_ID
# Note: mcp and vault have no compose secret refs — no AppRole creds needed

# Vault OIDC (Keycloak SSO for vault UI)
VAULT_OIDC_CLIENT_SECRET=REPLACE_WITH_KEYCLOAK_CLIENT_SECRET

# Vault sync token (read-only, for automated vault-to-SOPS sync)
VAULT_SYNC_TOKEN=REPLACE_WITH_SYNC_TOKEN
